    "homepage": "https://github.com/yishengjiang99/ssr-ctx#readme",
    "devDependencies": {
        "@tsconfig/node14": "^1.0.0",
        "@types/chai": "^4.2.14",
        "@types/mocha": "^8.2.0",
        "@types/node": "^14.14.16",
        "chai": "^4.3.4",
        "mocha": "^8.2.1",
        "ts-node": "^9.1.1",
        "typescript": "^4.1.3"
